#include <string>
#include <vector>
#include <algorithm>
 
using namespace std;
 
// 내림차순 정렬
bool compare(int a, int b) {
    return a > b;
}
 
vector<int> solution(vector<int> emergency) {
    vector<int> answer;    
    vector<int> index = emergency;    
    sort(index.begin(), index.end(), compare);  
    int length = emergency.size();
    
    // 응급도 높은 순서대로 정렬
    for(int i = 0; i < length; i++) {
        for(int j = 0; j < length; j++) {
            if (emergency[i] == index[j]) {
                answer.push_back(j + 1);
                break;
            }
        }
    }
    
    return answer;
}
