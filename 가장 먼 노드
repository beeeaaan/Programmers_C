#include <bits/stdc++.h>
using namespace std;

int solution(int n, vector<vector<int>> edge) {
    vector<vector<int>> graph(n + 1);
    
    // 인접 리스트 생성(양방향 그래프)
    for (auto &e : edge) {
        graph[e[0]].push_back(e[1]);
        graph[e[1]].push_back(e[0]);
    }

    vector<int> dist(n + 1, -1);  // 거리 배열(-1 : 방문 안함)
    queue<int> q;
    q.push(1);
    dist[1] = 0;  // 시작 노드 거리

    // 최단거리 구하기(BFS 활용)
    while (!q.empty()) {
        int cur = q.front();
        q.pop();

        for (int next : graph[cur]) {
            // 아직 방문 안한 경우
            if (dist[next] == -1) {
                dist[next] = dist[cur] + 1;
                q.push(next);
            }
        }
    }

    // 가장 먼 거리 찾기
    int maxDist = *max_element(dist.begin(), dist.end());
    // 가장 먼 거리의 노드 개수 세기
    int answer = 0;
    
    for (int i = 1; i <= n; i++) {
        if (dist[i] == maxDist) answer++;
    }

    return answer;
}
