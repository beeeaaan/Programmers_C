#include <string>
#include <vector>
#include <algorithm>

using namespace std;

// mid명 사람 건널 수 있는지 확인하는 함수
bool binary_search(vector<int> stones, int k, int mid) {
    int count = 0;
    
    for(int i = 0; i < stones.size(); i++) {
        // mid명이 지나갈 경우 돌의 값 = stones[i] - mid
        // 음수 되면 못 밟는 돌
        if(stones[i] < mid )
            count++;
        // 다시 밟을 수 있을 경우 초기화
        else    
            count = 0;
        
        // k개 연속으로 못 밟을 경우 건널 수 없음
        if(count >= k)    
            return false;
    }
    // 끝까지 문제 없을 경우 건널 수 있음
    return true;
}

int solution(vector<int> stones, int k) {
    int answer = 0;    
    int left = 1;
    int right = *max_element(stones.begin(), stones.end());
    
    // 이분 탐색
    while(left <= right) {
        int middle = (left + right) / 2;
        
        // middle명 건널 수 있을 경우 늘리기
        if(binary_search(stones, k, middle)) {
            left = middle + 1;
            answer = middle;
        }
        // 못 건널 경우 줄이기
        else {
            right = middle - 1;
        }     
    }

    return answer;
}
